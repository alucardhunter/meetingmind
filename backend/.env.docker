# Database (use 'db' as hostname when using docker-compose)
DATABASE_URL="postgresql://meetingmind:meetingmind_dev@db:5432/meetingmind?schema=public"

# JWT
JWT_SECRET="meetingmind-dev-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# OpenAI
OPENAI_API_KEY=""

# Notion (optional)
NOTION_API_KEY=""
NOTION_DATABASE_ID=""

# Slack (optional)
SLACK_WEBHOOK_URL=""

# Server
PORT=3001
NODE_ENV=development

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800
