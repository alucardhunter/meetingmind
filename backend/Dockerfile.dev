FROM node:22-alpine

WORKDIR /app

RUN apk add --no-cache openssl ffmpeg

COPY package*.json ./
RUN npm ci

COPY prisma ./prisma
RUN npx prisma generate

COPY . .

RUN mkdir -p uploads

EXPOSE 3001

ENV NODE_ENV=development
ENV PORT=3001

# Run db push (sync schema) and start server
CMD ["sh", "-c", "npx prisma db push && npm run dev"]
